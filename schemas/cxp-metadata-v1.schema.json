{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cybercore.dev/schemas/cxp-metadata-v1.schema.json",
  "title": "CyberCore CXP Metadata v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "title",
    "description",
    "rollback_supported"
  ],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      },
      "uniqueItems": true
    },
    "estimated_apply_seconds": {
      "type": "integer",
      "minimum": 0
    },
    "rollback_supported": {
      "type": "boolean"
    },
    "requires_restart": {
      "type": "boolean"
    },
    "affected_components": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "notes": {
      "type": "string"
    }
  }
}
